# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your_flask_secret_key_here
JWT_SECRET_KEY=your_jwt_secret_key_here

# Database Connection (Leave blank to fallback to SQLite for local testing)
# Example: postgresql://username:password@localhost:5432/sales_order_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/sales_order_db

# App Settings
PORT=5000
DEBUG=True
